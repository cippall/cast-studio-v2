{
  "name": "cast-studio-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "client",
    "packages/types"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server & npm run dev --workspace=client & wait",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=packages/types && npm run build --workspace=server && npm run build --workspace=client",
    "test": "npm run test --workspace=server --workspace=client",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern dist --ignore-pattern build",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "typecheck": "npm run typecheck --workspace=server && npm run typecheck --workspace=client",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
